<!doctype html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body data-page="home">
  <%- include('partials/header') %>

  <section class="hero">
    <div class="container">
      <form class="hero-search" action="/inventory" method="get">
        <select name="model">
          <option value="">All Models</option>
          <% models.forEach(function(m) { %>
            <option value="<%= m %>"><%= m %></option>
          <% }) %>
        </select>
        <select name="condition">
          <option value="">New or Used</option>
          <option value="new">New</option>
          <option value="used">Used</option>
        </select>
        <button type="submit">Search Inventory</button>
      </form>
    </div>
  </section>

  <section class="container featured">
    <div class="section-heading">
      <h2>Featured Vehicles</h2>
      <a href="/inventory">View All Inventory &rarr;</a>
    </div>
    <div class="vehicle-grid">
      <% featured.forEach(function(v) { %>
        <%- include('partials/vehicle-card', { v }) %>
      <% }) %>
    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>
