<%
  const driveTrainLabels = { AWD: 'All-wheel drive', FWD: 'Front-wheel drive', RWD: 'Rear-wheel drive' };
  const cardDriveTrain = driveTrainLabels[v.drivetrain] || v.drivetrain;
%>
<a class="vehicle-card" href="/inventory/<%= v.slug %>">
  <h3 class="vehicle-card-title"><%= v.year %> <%= v.model %> <%= v.trim %></h3>

  <div class="vehicle-card-img">
    <img src="<%= v.image %>" alt="<%= v.year %> Mazda <%= v.model %>" loading="lazy">
  </div>

  <div class="vehicle-card-price-row">
    <p class="vehicle-card-price-label">Dealer Price</p>
    <p class="vehicle-card-price"><span class="currency">$</span><%= v.price.toLocaleString() %></p>
  </div>

  <ul class="vehicle-card-specs">
    <li>Mileage: <%= v.mileage.toLocaleString() %></li>
    <li>Exterior: <%= v.exteriorColor %></li>
    <li>Interior: <%= v.interiorColor %></li>
    <li>Transmission: <%= v.transmission %></li>
    <li>Engine: <%= v.engine %></li>
    <li>Drivetrain: <%= cardDriveTrain %></li>
  </ul>
</a>
